{
  "name": "oneapichat",
  "version": "2.4.0",
  "description": "OneAPIChat - 多模型AI聊天客户端",
  "main": "electron_main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:mac": "electron-builder --mac --x64",
    "build:all": "electron-builder --win --linux --mac --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.oneapichat.app",
    "productName": "OneAPIChat",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron_main.js",
      "index.html",
      "login.html",
      "js/**/*",
      "css/**/*",
      "lib/**/*",
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/favicon-256x256.png",
      "artifactName": "OneAPIChat-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/favicon-256x256.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/favicon-256x256.png"
    }
  },
  "keywords": ["chat", "ai", "oneapi"],
  "author": "naujtrats",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
