// 测试直接 MiniMax API
window.testDirectMiniMaxAPI = async function() {
    console.log('=== 测试直接 MiniMax API ===');

    try {
        // 使用有效的 1x1 红色 PNG
        const testBase64 = 'iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNkYPj/HwADBwIAMCbHYQAAAABJRU5ErkJggg==';
        const result = await window.analyzeImage('data:image/png;base64,' + testBase64, '测试图片描述');

        console.log('✅ MiniMax API 测试成功');
        console.log('结果:', result.substring(0, 200));
        return result;
    } catch (error) {
        console.error('❌ MiniMax API 测试失败:', error.message);

        // 提供调试信息
        if (error.message.includes('401')) {
            console.log('🔧 问题: API Key 无效或过期');
            console.log('   建议: 检查 MiniMax Token Plan API Key');
        } else if (error.message.includes('400')) {
            console.log('🔧 问题: 请求格式错误');
            console.log('   建议: 检查 base64 格式和请求结构');
        } else if (error.message.includes('network')) {
            console.log('🔧 问题: 网络连接问题');
            console.log('   建议: 检查网络和代理设置');
        }

        throw error;
    }
};

