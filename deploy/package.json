{
  "name": "oneapichat-client",
  "version": "2.5.0",
  "description": "OneAPIChat 桌面客户端 — 瘦客户端模式，连接远程服务器",
  "main": "electron_main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux --x64",
    "build:mac": "electron-builder --mac --x64",
    "build:all": "electron-builder --win --linux --mac --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.oneapichat.client",
    "productName": "OneAPIChat",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "chickenyoutoo-beautiful",
      "repo": "oneapichat",
      "releaseType": "release"
    },
    "files": [
      "electron_main.js",
      "preload.js",
      "../public/resource/icon-512.png",
      "!node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "../public/resource/icon-512.png",
      "artifactName": "OneAPIChat-Setup-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OneAPIChat",
      "installerIcon": "../public/resource/icon-256.ico",
      "uninstallerIcon": "../public/resource/icon-256.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../public/resource/icon-512.png",
      "artifactName": "OneAPIChat-${version}-linux-x64.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "../public/resource/icon-512.png",
      "artifactName": "OneAPIChat-${version}-mac-x64.${ext}"
    }
  },
  "keywords": ["chat", "ai", "oneapi", "desktop", "electron"],
  "author": "naujtrats",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-updater": "^6.6.2"
  }
}
